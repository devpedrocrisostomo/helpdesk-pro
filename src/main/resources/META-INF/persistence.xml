<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_1.xsd"
             version="3.1">
    <persistence-unit name="helpdeskPU" transaction-type="JTA">
        <jta-data-source>java:/jdbc/HelpDeskDS</jta-data-source>
        <class>com.helpdeskpro.model.entity.User</class>
        <class>com.helpdeskpro.model.entity.Client</class>
        <class>com.helpdeskpro.model.entity.Ticket</class>
        <class>com.helpdeskpro.model.entity.Comment</class>
        <class>com.helpdeskpro.model.entity.TicketHistory</class>
        <properties>
            <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.jdbc.time_zone" value="UTC"/>
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="true"/>
        </properties>
    </persistence-unit>
</persistence>
